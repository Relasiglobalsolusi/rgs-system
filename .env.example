# =============================================================================
# RGS ONE (ERP) — environment template
# Copy to `.env` locally, or set the same keys on your host (PM2 / panel / Vercel).
# Never commit real secrets. Do not put API keys in NEXT_PUBLIC_* variables.
# =============================================================================
#
# Runtime: Node.js 20+ · Next.js 16 · PostgreSQL · Prisma
#
# Hosting (Indonesian / RumahWeb):
#   - Shared hosting (typical PHP-only) CANNOT run this app.
#   - Prefer RumahWeb VPS / Cloud: Node 20, PM2 (or systemd), Nginx + HTTPS,
#     persistent disk for public/uploads, Postgres on the VPS or managed.
#   - Vercel is OPTIONAL (convenient for Next.js) but NOT required if the VPS
#     already runs `npm run build` + `npm start`. Uploads on Vercel are ephemeral.
#   - Corporate site (e.g. LaunchUniversal) can stay on a separate host.
#     Point erp.your-domain.com (or one.your-domain.com) at the ERP host only.
#
# =============================================================================

# ─── Required ───────────────────────────────────────────────────────────────

# PostgreSQL connection string (MySQL is not supported by this Prisma schema)
# Local:
DATABASE_URL="postgresql://rgs_user:your_password@localhost:5432/rgs_system"
# Production — use SSL when the host requires it; prefer a pooled URL if offered
# (Neon / Supabase pooler / managed Postgres):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/rgs_system?sslmode=require"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# App public URL (no trailing slash). Must match the browser URL (HTTPS in prod).
# Local (`npm run dev` → port 3000):
NEXTAUTH_URL="http://localhost:3000"
# Production examples:
# NEXTAUTH_URL="https://one.rgs.co.id"
# NEXTAUTH_URL="https://erp.your-domain.com"

# Optional alias used by invoice email deep-links (defaults to NEXTAUTH_URL)
# APP_URL="https://one.rgs.co.id"

# ─── AI — payment proof & tax invoice verification (OpenAI Vision) ───────────
#
# Used ONLY on the server (lib/payment-document-verify.ts → OpenAI Chat Completions).
# The key is never exposed to the browser. Do NOT use NEXT_PUBLIC_OPENAI_*.
#
# Fail-closed: if OPENAI_API_KEY is missing/invalid, or extracted fields do not
# match invoice + company bank + client, Payment received / Tax invoice done
# is REJECTED (upload may still be stored for audit; status is not advanced).
#
# Setup for production:
#   1. Create an OpenAI account → API keys → create a secret key (sk-...).
#   2. Add billing / credits (Vision calls bill against your OpenAI account).
#   3. Set OPENAI_API_KEY on the ERP host only (VPS .env or host env UI).
#   4. Ensure outbound HTTPS from the server to api.openai.com is allowed.
#   5. Set company bank in Company settings (DB) and/or COMPANY_BANK_* below.
#
# OPENAI_API_KEY="sk-..."
# Optional model override (default gpt-4o-mini; needs vision-capable model):
# OPENAI_PAYMENT_VERIFY_MODEL="gpt-4o-mini"
#
# Company recipient bank (fallback when Company.bank* DB fields are empty):
# COMPANY_BANK_ACCOUNT_NUMBER="1234567890"
# COMPANY_BANK_NAME="BCA"
# COMPANY_BANK_ACCOUNT_NAME="PT Relasi Global Solusi"
#
# Company Tax ID (NPWP) for PPN masukan (purchase) tax-invoice buyer checks.
# Optional: when set, buyer NPWP on uploaded faktur must match. When unset, NPWP check is skipped.
# COMPANY_NPWP="01.234.567.8-901.000"

# ─── Website CMS (corporate site → ERP API) — optional ───────────────────────
# Corporate site may live on LaunchUniversal (or elsewhere); only needed if it
# fetches CMS JSON from this ERP.

# Public site origin for CORS on GET /api/website/content
# WEBSITE_CORS_ORIGIN="https://rgs.co.id"

# Optional shared secret; public site must send header x-api-key
# WEBSITE_CMS_API_KEY="shared-secret-with-website"

# On the corporate website project, set (examples):
# NEXT_PUBLIC_CMS_URL="https://one.rgs.co.id/api/website/content"
# NEXT_PUBLIC_PORTAL_URL="https://one.rgs.co.id/login"
# CMS_API_KEY="same-as-WEBSITE_CMS_API_KEY-if-set"

# ─── SMTP (invoice / password-reset email) — optional but recommended ────────
# Requires: npm i nodemailer (and @types/nodemailer) — not bundled by default.
# Without SMTP_HOST, invoice email is stubbed (logged only).
# SMTP_HOST="smtp.rumahweb.com"
# SMTP_PORT="465"
# SMTP_USER="noreply@rgs.co.id"
# SMTP_PASS="your-smtp-password"
# SMTP_FROM="Relasi Global Solusi <noreply@rgs.co.id>"

# ─── Maps (optional) ─────────────────────────────────────────────────────────
# Projects use OpenStreetMap/Leaflet by default; no key required.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"
# NOMINATIM_CONTACT_EMAIL="noreply@rgs.co.id"
# NOMINATIM_USER_AGENT="RGS-System/1.0 (noreply@rgs.co.id)"

# ─── Deploy notes ────────────────────────────────────────────────────────────
# RumahWeb VPS (recommended for this ERP):
#   1. Node 20+, Postgres, Nginx reverse proxy, PM2 → `npm start` (port 3000).
#   2. See scripts/deploy-rumahweb.sh (adjust ERP_DOMAIN if needed).
#   3. After deploy: npx prisma migrate deploy && npm run build && pm2 restart …
#   4. Back up public/uploads (payment proofs, CICO photos, tax docs, PDFs).
#
# Vercel (optional alternative):
#   1. Production DATABASE_URL is required (local Postgres is unreachable).
#   2. Build runs prisma migrate deploy via vercel.json.
#   3. File uploads under public/uploads are ephemeral — plan Blob/S3/R2 or use VPS.
#   4. Set the same env vars in Project Settings → Environment Variables.
